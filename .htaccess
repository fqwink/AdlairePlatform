RedirectMatch 403 ^.*/files/
RedirectMatch 403 ^.*/data/
RedirectMatch 403 ^.*/backup/
RedirectMatch 403 ^.*/engines/.*\.php$
RedirectMatch 403 ^.*/controllers/.*\.php$
RedirectMatch 403 ^.*/Framework/.*\.php$
ErrorDocument 403 &nbsp;
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "same-origin"
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self'; frame-ancestors 'self'"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>
RewriteEngine on
Options -Indexes

# ── 静的ファイル優先配信（Static-First モード） ──────────────────
# static/index.html が存在すればトップページを静的配信
RewriteCond %{DOCUMENT_ROOT}/%{REQUEST_URI}/static/index.html -f [OR]
RewriteCond static/index.html -f
RewriteCond %{QUERY_STRING} !(?:^|&)(ap_action|ap_api|admin|login)
RewriteRule ^$ static/index.html [L]

# /slug → static/slug/index.html が存在すれば静的配信
# Ver.1.7: Router パス（login, admin, logout, dispatch）は静的配信をスキップ
RewriteCond static/%1/index.html -f
RewriteCond %{QUERY_STRING} !(?:^|&)(ap_action|ap_api|admin|login)
RewriteRule ^(?!login|admin|logout|dispatch|api/)([a-zA-Z0-9_-]+)/?$ static/$1/index.html [L]

# static/ 内の既存ファイルへの直接アクセスはそのまま通す
RewriteRule ^static/ - [L]

# ── 動的 PHP（index.php へのフォールバック） ──────────────────
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond $1#%{REQUEST_URI} ([^#]*)#(.*)\1$
RewriteRule ^([^\.]+)$ %2?page=$1 [QSA,L]
