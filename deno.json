{
  "name": "@adlaire/platform",
  "version": "2.1.41",
  "exports": "./Framework/mod.ts",
  "tasks": {
    "start": "deno run --allow-net --allow-read --allow-write --allow-env --allow-run main.ts",
    "dev": "deno run --watch --allow-net --allow-read --allow-write --allow-env --allow-run main.ts",
    "check": "deno check Framework/AFE/*.ts Framework/ACS/ACS.*.ts Framework/ACS/ACS.d.ts Framework/ACE/*.ts Framework/AIS/*.ts Framework/ASG/*.ts Framework/AP/*.ts Framework/AEB/AEB.*.ts Framework/mod.ts main.ts bootstrap.ts routes.ts",
    "check:browser": "deno check --config Framework/browser.deno.json Framework/AEB/*.ts Framework/*/ClientEngine/*.ts",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "test": "deno test --allow-read --allow-write --allow-net tests/"
  },
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "lint": {
    "include": ["Framework/**/*.ts", "main.ts", "bootstrap.ts", "routes.ts"],
    "exclude": ["Framework/ADS/"],
    "rules": {
      "tags": ["recommended"],
      "exclude": ["no-explicit-any"]
    }
  },
  "fmt": {
    "include": ["Framework/**/*.ts", "main.ts", "bootstrap.ts", "routes.ts"],
    "exclude": ["Framework/ADS/"],
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": false,
    "proseWrap": "preserve"
  }
}
